
// Autentikasi (CONTOH - TIDAK AMAN UNTUK PRODUKSI)
document.getElementById('loginForm').addEventListener('submit', function(event) {
    event.preventDefault();

    const username = document.getElementById('username').value;
    const password = document.getElementById('password').value;
    const loginMessage = document.getElementById('loginMessage');

    // Simpan kredensial yang di-hash di sisi server (JANGAN SIMPAN PASSWORD ASLI)
    // Contoh: Hash password menggunakan bcrypt atau algoritma serupa di sisi server
    const hashedPassword = '$2b$10$EXAMPLE_HASHED_PASSWORD'; // Ganti dengan hash yang sebenarnya

    // Kirim permintaan ke server untuk memverifikasi kredensial
    fetch('/login', { // Ganti '/login' dengan endpoint yang sesuai di server Anda
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ username: username, password: password })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            loginMessage.textContent = 'Login berhasil!';
            loginMessage.style.color = 'green';
            // Redirect ke halaman admin atau lakukan tindakan lain
        } else {
            loginMessage.textContent = 'ID Pengguna atau Kata Sandi salah.';
            loginMessage.style.color = 'red';
        }
    })
    .catch(error => {
        console.error('Error:', error);
        loginMessage.textContent = 'Terjadi kesalahan. Coba lagi nanti.';
        loginMessage.style.color = 'red';
    });
});

// Pencarian (CONTOH - PERLU IMPLEMENTASI SISI SERVER)
document.getElementById('searchForm').addEventListener('submit', function(event) {
    event.preventDefault();

    const searchTerm = document.getElementById('searchTerm').value;
    const searchResults = document.getElementById('searchResults');

    // Kirim permintaan ke server untuk melakukan pencarian
    fetch('/search?q=' + encodeURIComponent(searchTerm), { // Ganti '/search' dengan endpoint yang sesuai di server Anda
        method: 'GET'
    })
    .then(response => response.json())
    .then(data => {
        searchResults.innerHTML = ''; // Kosongkan hasil sebelumnya
        if (data.results && data.results.length > 0) {
            data.results.forEach(result => {
                const resultElement = document.createElement('p');
                resultElement.textContent = result.title + ' - ' + result.description; // Sesuaikan dengan struktur data yang diterima dari server
                searchResults.appendChild(resultElement);
            });
        } else {
            searchResults.textContent = 'Tidak ada hasil ditemukan.';
        }
    })
    .catch(error => {
        console.error('Error:', error);
        searchResults.textContent = 'Terjadi kesalahan. Coba lagi nanti.';
    });
} ) ;